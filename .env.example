# LLM Wiki Builder - Environment Configuration
# Copy this file to .env and fill in your values

# ============================
# LLM Backend Selection
# ============================
# Options: ollama | openai | anthropic
LLM_BACKEND=ollama

# ============================
# Ollama (Local)
# ============================
OLLAMA_MODEL=llama3.1

# ============================
# OpenAI
# ============================
OPENAI_API_KEY=sk-
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================
# Anthropic (Claude)
# ============================
ANTHROPIC_API_KEY=sk-ant-
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================
# Wiki Configuration
# ============================
# Target wiki subdirectory name
WIKI_SUBDIR=my-wiki

# Python UTF-8 mode (Windows only)
# Set before running scripts: set PYTHONUTF8=1 (CMD) or $env:PYTHONUTF8=1 (PowerShell)
PYTHONUTF8=1
